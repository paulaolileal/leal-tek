---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import { products } from '../../data/products';
---

<BaseLayout
  title="Products"
  description="What we build — MindCircle and the Myth Ecosystem. Two products built for scale, clarity, and real-world impact."
>
  <section class="hero section">
    <div class="container">
      <div class="hero-inner reveal">
        <span class="section-label">Products</span>
        <span class="gold-line"></span>
        <h1>What We Build</h1>
        <p class="hero-sub">
          Two products at different scales — a collaborative SaaS platform and a production-ready
          .NET library ecosystem. Both built from the ground up with clean architecture,
          real-world usage, and zero tolerance for unnecessary complexity.
        </p>
      </div>
    </div>
  </section>

  <section class="products-section section-sm">
    <div class="container">
      <div class="products-grid">
        {products.map((product, i) => (
          <article class={`product-card reveal reveal-delay-${i + 1}`}>
            <div class="card-top">
              <div class="card-header">
                <Badge variant={`status-${product.status}`}>
                  {product.status === 'active' ? 'Active' : 'In Progress'}
                </Badge>
                <span class="card-id">0{i + 1}</span>
              </div>
              <h2 class="product-name">{product.name}</h2>
              <p class="product-tagline">{product.tagline}</p>
            </div>

            <p class="product-description">{product.longDescription}</p>

            <div class="product-stack">
              {product.techStack.map(tech => (
                <Badge variant="tech">{tech}</Badge>
              ))}
            </div>

            <div class="card-footer">
              <Button href={product.href} variant="primary" size="md">
                Learn More →
              </Button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section section reveal">
    <div class="container">
      <div class="cta-inner">
        <p class="cta-label section-label">Let's Work Together</p>
        <h2 class="cta-title">Building something complex?<br /><span class="gold">Let's talk.</span></h2>
        <Button href="/contact" variant="primary" size="lg">Get in Touch</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-inner {
    max-width: 680px;
  }

  .hero-inner h1 {
    margin-top: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 560px;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  @media (max-width: 900px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
  }

  .product-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    position: relative;
    overflow: hidden;
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
  }

  .product-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(200, 151, 58, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  .product-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: var(--shadow-card);
  }

  .card-top {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-id {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  .product-name {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    line-height: 1;
  }

  .product-tagline {
    font-size: 0.95rem;
    color: var(--gold-primary);
    font-weight: 600;
    margin: 0;
  }

  .product-description {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.75;
    flex: 1;
  }

  .product-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .card-footer {
    padding-top: var(--space-sm);
    border-top: 1px solid var(--border);
  }

  .cta-section {
    border-top: 1px solid var(--border);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-xl);
    padding-block: var(--space-2xl);
  }

  .cta-label {
    margin-bottom: calc(-1 * var(--space-md));
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
  }
</style>
