---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import { products } from '../../data/products';

const product = products.find(p => p.id === 'mindcircle')!;
---

<BaseLayout
  title="MindCircle"
  description="Visual thinking, powered by AI. A collaborative SaaS platform for knowledge management with real-time collaboration and GPT-4o integration."
>
  <section class="hero section">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-meta reveal">
          <Badge variant="status-active">Active</Badge>
          <span class="hero-slash">/</span>
          <span class="hero-category section-label">SaaS Platform</span>
        </div>
        <h1 class="hero-title reveal reveal-delay-1">MindCircle</h1>
        <p class="hero-tagline reveal reveal-delay-2">{product.tagline}</p>
        <p class="hero-desc reveal reveal-delay-3">{product.longDescription}</p>
      </div>
    </div>
  </section>

  <section class="features-section section-sm">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Core Features</span>
        <span class="gold-line"></span>
        <h2>Built for the way you think</h2>
      </div>
      <div class="features-grid">
        {product.features.map((feature, i) => (
          <div class={`feature-card reveal reveal-delay-${(i % 3) + 1}`}>
            <span class="feature-num">0{i + 1}</span>
            <h3 class="feature-title">{feature.title}</h3>
            <p class="feature-desc">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="stack-section section-sm">
    <div class="container">
      <div class="stack-inner reveal">
        <span class="section-label">Tech Stack</span>
        <span class="gold-line"></span>
        <h2>What powers it</h2>
        <div class="stack-grid">
          {product.techStack.map(tech => (
            <Badge variant="tech">{tech}</Badge>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section section reveal">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-icon">◎</div>
        <h2>Stay tuned — early access coming soon.</h2>
        <p>MindCircle is actively being built. Follow along on LinkedIn for updates and early access announcements.</p>
        <Button
          href="https://linkedin.com/in/paulaolileal"
          variant="primary"
          size="lg"
          target="_blank"
          rel="noopener noreferrer"
        >
          Follow on LinkedIn
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-inner {
    max-width: 760px;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .hero-slash {
    color: var(--border-accent);
    font-size: 1.2rem;
  }

  .hero-category {
    color: var(--text-muted);
  }

  .hero-title {
    font-size: clamp(3.5rem, 9vw, 7rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-lg);
  }

  .hero-tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    color: var(--gold-primary);
    font-weight: 600;
    font-family: var(--font-display);
    margin-bottom: var(--space-xl);
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 620px;
  }

  .section-header {
    margin-bottom: var(--space-2xl);
  }

  .section-header h2 {
    margin-top: var(--space-sm);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    transition: border-color var(--transition), transform var(--transition);
    position: relative;
  }

  .feature-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
  }

  .feature-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--gold-dim);
    letter-spacing: 0.1em;
  }

  .feature-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .feature-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .stack-section {
    border-top: 1px solid var(--border);
  }

  .stack-inner {
    max-width: 700px;
  }

  .stack-inner h2 {
    margin-top: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .stack-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .cta-section {
    border-top: 1px solid var(--border);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-lg);
    padding-block: var(--space-2xl);
    max-width: 560px;
    margin-inline: auto;
  }

  .cta-icon {
    font-size: 2.5rem;
    color: var(--gold-primary);
    line-height: 1;
  }

  .cta-inner h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
  }

  .cta-inner p {
    font-size: 0.95rem;
    color: var(--text-secondary);
  }
</style>
