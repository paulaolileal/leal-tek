---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import { products, mythPackages } from '../../data/products';

const product = products.find(p => p.id === 'myth')!;

const whyPoints = [
  {
    title: 'Zero boilerplate',
    description: 'Fluent APIs and smart conventions eliminate repetitive setup. Write what matters.',
  },
  {
    title: 'DDD native',
    description: 'Domain-Driven Design is first-class. Every library is designed around bounded contexts and aggregate roots.',
  },
  {
    title: 'Perfect integration',
    description: 'All 11 packages share a global service provider and follow the same conventions — they just work together.',
  },
];
---

<BaseLayout
  title="Myth Ecosystem"
  description="Production-ready .NET libraries for clean architecture. 11 NuGet packages for DDD, CQRS, validation, pipelines, and more."
>
  <section class="hero section">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-meta reveal">
          <Badge variant="status-active">Active</Badge>
          <span class="hero-slash">/</span>
          <span class="hero-category section-label">.NET Library Ecosystem</span>
        </div>
        <h1 class="hero-title reveal reveal-delay-1">Myth Ecosystem</h1>
        <p class="hero-tagline reveal reveal-delay-2">{product.tagline}</p>
        <p class="hero-desc reveal reveal-delay-3">{product.longDescription}</p>
        <div class="hero-actions reveal reveal-delay-4">
          <Button
            href={product.nugetUrl}
            variant="primary"
            size="lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            View on NuGet
          </Button>
          <Button
            href={product.gitlabUrl}
            variant="secondary"
            size="lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            GitLab Source
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section class="packages-section section-sm">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">NuGet Packages</span>
        <span class="gold-line"></span>
        <h2>11 focused libraries</h2>
        <p class="section-sub">Each package solves one concern — and they all fit together.</p>
      </div>
      <div class="packages-grid">
        {mythPackages.map((pkg, i) => (
          <div class={`package-card reveal reveal-delay-${(i % 4) + 1}`}>
            <span class="pkg-name">{pkg.name}</span>
            <p class="pkg-desc">{pkg.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="why-section section-sm">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Philosophy</span>
        <span class="gold-line"></span>
        <h2>Why Myth?</h2>
      </div>
      <div class="why-grid">
        {whyPoints.map((point, i) => (
          <div class={`why-card reveal reveal-delay-${i + 1}`}>
            <span class="why-num">0{i + 1}</span>
            <h3 class="why-title">{point.title}</h3>
            <p class="why-desc">{point.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="stack-section section-sm">
    <div class="container">
      <div class="stack-inner reveal">
        <span class="section-label">Built With</span>
        <span class="gold-line"></span>
        <div class="stack-row">
          {product.techStack.map(tech => (
            <Badge variant="tech">{tech}</Badge>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section section reveal">
    <div class="container">
      <div class="cta-inner">
        <h2>Ready to use Myth in your project?</h2>
        <p>All packages are available on NuGet. Source code and documentation live on GitLab.</p>
        <div class="cta-actions">
          <Button
            href={product.nugetUrl}
            variant="primary"
            size="lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Browse on NuGet
          </Button>
          <Button
            href={product.gitlabUrl}
            variant="ghost"
            size="lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Explore on GitLab
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-inner {
    max-width: 760px;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .hero-slash {
    color: var(--border-accent);
    font-size: 1.2rem;
  }

  .hero-category {
    color: var(--text-muted);
  }

  .hero-title {
    font-size: clamp(2.5rem, 7vw, 6rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-lg);
  }

  .hero-tagline {
    font-size: clamp(1rem, 2.2vw, 1.3rem);
    color: var(--gold-primary);
    font-weight: 600;
    font-family: var(--font-display);
    margin-bottom: var(--space-xl);
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 640px;
    margin-bottom: var(--space-2xl);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .section-header {
    margin-bottom: var(--space-2xl);
  }

  .section-header h2 {
    margin-top: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .section-sub {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .packages-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 1100px) {
    .packages-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .packages-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .packages-grid {
      grid-template-columns: 1fr;
    }
  }

  .package-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: border-color var(--transition), transform var(--transition);
  }

  .package-card:hover {
    border-color: rgba(200, 151, 58, 0.25);
    transform: translateY(-1px);
  }

  .pkg-name {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--gold-primary);
    letter-spacing: 0.02em;
    word-break: break-word;
  }

  .pkg-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  .why-section {
    border-top: 1px solid var(--border);
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  @media (max-width: 768px) {
    .why-grid {
      grid-template-columns: 1fr;
    }
  }

  .why-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-xl);
    border-left: 2px solid var(--gold-primary);
    background: var(--bg-card);
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
  }

  .why-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--gold-dim);
    letter-spacing: 0.1em;
  }

  .why-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .why-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .stack-section {
    border-top: 1px solid var(--border);
  }

  .stack-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .stack-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .cta-section {
    border-top: 1px solid var(--border);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-lg);
    padding-block: var(--space-2xl);
    max-width: 560px;
    margin-inline: auto;
  }

  .cta-inner h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
  }

  .cta-inner p {
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .cta-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
