---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.date.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

let embedHtml: string | null = null;
try {
  const oembedUrl = `https://www.linkedin.com/oembed?url=${encodeURIComponent(post.data.linkedinUrl)}&format=json`;
  const response = await fetch(oembedUrl);
  if (response.ok) {
    const data = await response.json();
    embedHtml = data.html ?? null;
  }
} catch {
  embedHtml = null;
}
---

<BaseLayout title={post.data.title} description={post.data.excerpt} alternatePath="/en/blog">
  <article class="post-wrapper">

    <header class="post-header">
      <div class="container">
        <div class="header-inner">
          <div class="header-meta">
            <time class="post-date" datetime={post.data.date.toISOString()}>
              {formattedDate}
            </time>
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <Badge variant="tech">#{tag}</Badge>
              ))}
            </div>
          </div>

          <h1 class="post-title">{post.data.title}</h1>
          <p class="post-excerpt">{post.data.excerpt}</p>

          <div class="header-divider" aria-hidden="true">
            <span class="divider-line"></span>
            <svg class="divider-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
            <span class="divider-line"></span>
          </div>
        </div>
      </div>
    </header>

    <div class="post-body">
      <div class="container">
        <div class="post-content prose">
          <Content />
        </div>

        <aside class="post-linkedin">
          <div class="linkedin-section-label">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span>Originally shared on LinkedIn</span>
          </div>

          {embedHtml ? (
            <div class="linkedin-embed" set:html={embedHtml} />
          ) : (
            <div class="linkedin-fallback">
              <div class="fallback-inner">
                <div class="fallback-icon" aria-hidden="true">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </div>
                <div class="fallback-text">
                  <p class="fallback-title">Ver post original</p>
                  <p class="fallback-sub">Este artigo foi publicado originalmente no LinkedIn.</p>
                </div>
                <a
                  href={post.data.linkedinUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="fallback-link"
                >
                  Ver post original no LinkedIn
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
                  </svg>
                </a>
              </div>
            </div>
          )}
        </aside>

        <footer class="post-cta">
          <div class="cta-inner">
            <div class="cta-text">
              <span class="section-label">Gostou?</span>
              <h2 class="cta-title">Siga no LinkedIn para mais conteúdo.</h2>
              <p class="cta-sub">
                Arquitetura, cultura de engenharia e open-source — novas publicações toda semana.
              </p>
            </div>
            <Button
              href="https://www.linkedin.com/in/paulaolileal"
              variant="primary"
              size="lg"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              Seguir no LinkedIn
            </Button>
          </div>
        </footer>

        <nav class="post-nav">
          <a href="/blog" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M19 12H5M12 5l-7 7 7 7"/>
            </svg>
            Back to Blog
          </a>
        </nav>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-wrapper {
    min-height: calc(100vh - var(--header-height));
  }

  /* ── Header ──────────────────────────────────────────────── */
  .post-header {
    padding-block: var(--space-4xl) var(--space-2xl);
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .post-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(200, 151, 58, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .header-inner {
    max-width: 740px;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .post-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .post-excerpt {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 620px;
  }

  .header-divider {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-top: var(--space-sm);
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--gold-primary), transparent);
    max-width: 80px;
  }

  .divider-line:last-child {
    background: linear-gradient(to left, transparent, transparent);
    max-width: 40px;
  }

  .divider-icon {
    color: var(--gold-primary);
    flex-shrink: 0;
  }

  /* ── Body ────────────────────────────────────────────────── */
  .post-body {
    padding-block: var(--space-3xl);
  }

  .post-body .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  /* ── Prose / Content ─────────────────────────────────────── */
  .post-content {
    max-width: 680px;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    position: relative;
    padding-left: var(--space-md);
  }

  .prose :global(h2)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.15em;
    bottom: 0.15em;
    width: 3px;
    background: var(--gold-primary);
    border-radius: 2px;
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .prose :global(p) {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
  }

  .prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-xl);
    margin-bottom: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .prose :global(li) {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .prose :global(ul li)::marker {
    color: var(--gold-primary);
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--text-primary);
  }

  .prose :global(em) {
    font-style: italic;
    color: var(--text-secondary);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--gold-light);
    background: rgba(200, 151, 58, 0.08);
    border: 1px solid rgba(200, 151, 58, 0.15);
    padding: 1px 6px;
    border-radius: var(--radius-sm);
  }

  .prose :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    overflow-x: auto;
    margin-bottom: var(--space-lg);
  }

  .prose :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
    font-size: 0.875rem;
    color: var(--text-primary);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--gold-primary);
    padding-left: var(--space-lg);
    margin: var(--space-xl) 0;
    font-style: italic;
  }

  .prose :global(blockquote p) {
    color: var(--text-secondary);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin-block: var(--space-2xl);
  }

  .prose :global(a) {
    color: var(--gold-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(200, 151, 58, 0.4);
    transition: color var(--transition), text-decoration-color var(--transition);
  }

  .prose :global(a:hover) {
    color: var(--gold-light);
    text-decoration-color: var(--gold-light);
  }

  /* ── LinkedIn Section ────────────────────────────────────── */
  .post-linkedin {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .linkedin-section-label {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold-primary);
  }

  .linkedin-embed {
    border: 1px solid rgba(200, 151, 58, 0.25);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-width: 600px;
  }

  .linkedin-embed :global(iframe) {
    display: block;
    width: 100% !important;
  }

  .linkedin-fallback {
    border: 1px solid rgba(200, 151, 58, 0.2);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    max-width: 600px;
    overflow: hidden;
    transition: border-color var(--transition);
  }

  .linkedin-fallback:hover {
    border-color: rgba(200, 151, 58, 0.4);
  }

  .fallback-inner {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-xl);
    flex-wrap: wrap;
  }

  .fallback-icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: rgba(200, 151, 58, 0.08);
    border: 1px solid rgba(200, 151, 58, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold-primary);
  }

  .fallback-text {
    flex: 1;
    min-width: 180px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .fallback-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.2;
  }

  .fallback-sub {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.4;
  }

  .fallback-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--gold-primary);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--transition), gap var(--transition);
  }

  .fallback-link:hover {
    color: var(--gold-light);
    gap: 10px;
  }

  /* ── CTA ─────────────────────────────────────────────────── */
  .post-cta {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
  }

  .post-cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to right, var(--gold-primary), var(--gold-dim), transparent);
  }

  .cta-inner {
    padding: var(--space-2xl);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2xl);
    flex-wrap: wrap;
  }

  .cta-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 460px;
  }

  .cta-title {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .cta-sub {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ── Nav ─────────────────────────────────────────────────── */
  .post-nav {
    padding-top: var(--space-sm);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition), gap var(--transition);
  }

  .back-link:hover {
    color: var(--gold-primary);
    gap: calc(var(--space-sm) + 4px);
  }

  .back-link svg {
    transition: transform var(--transition);
  }

  .back-link:hover svg {
    transform: translateX(-3px);
  }

  @media (max-width: 768px) {
    .cta-inner { flex-direction: column; align-items: flex-start; }
    .fallback-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
