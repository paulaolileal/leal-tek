---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import { labProjects } from '../data/labs';

const statusLabel: Record<string, string> = {
  active: 'Active',
  wip: 'In Progress',
  complete: 'Complete',
};
---

<BaseLayout
  title="Labs"
  description="Experiments and explorations — personal projects exploring new ideas, architectures, and technologies."
>
  <section class="hero section">
    <div class="container">
      <div class="hero-inner reveal">
        <span class="section-label">Labs</span>
        <span class="gold-line"></span>
        <h1>Experiments &amp;<br />Explorations</h1>
        <p class="hero-sub">
          Personal projects exploring new ideas, architectures, and technologies.
          Some are finished. Some are still alive. All of them taught something useful.
        </p>
      </div>
    </div>
  </section>

  <section class="projects-section section-sm">
    <div class="container">
      <div class="projects-grid">
        {labProjects.map((project, i) => (
          <article class={`project-card reveal reveal-delay-${(i % 3) + 1}`}>
            <div class="card-top">
              <div class="card-header">
                <Badge variant={`status-${project.status}`}>
                  {statusLabel[project.status]}
                </Badge>
                <span class="project-id">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <h3 class="project-name">{project.name}</h3>
              <p class="project-tagline">{project.tagline}</p>
            </div>

            <p class="project-description">{project.description}</p>

            <div class="project-stack">
              {project.techStack.map(tech => (
                <Badge variant="tech">{tech}</Badge>
              ))}
            </div>

            {(project.demoUrl || project.gitlabUrl || project.githubUrl) && (
              <div class="project-links">
                {project.demoUrl && (
                  <Button href={project.demoUrl} variant="primary" size="sm" target="_blank" rel="noopener noreferrer">
                    Live Demo
                  </Button>
                )}
                {project.gitlabUrl && (
                  <Button href={project.gitlabUrl} variant="ghost" size="sm" target="_blank" rel="noopener noreferrer">
                    GitLab
                  </Button>
                )}
                {project.githubUrl && (
                  <Button href={project.githubUrl} variant="ghost" size="sm" target="_blank" rel="noopener noreferrer">
                    GitHub
                  </Button>
                )}
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-inner {
    max-width: 680px;
  }

  .hero-inner h1 {
    margin-top: var(--space-sm);
    margin-bottom: var(--space-lg);
    line-height: 1;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 520px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 1100px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
    position: relative;
    overflow: hidden;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-primary), transparent);
    opacity: 0;
    transition: opacity var(--transition);
  }

  .project-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .card-top {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .project-id {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  .project-name {
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.1;
  }

  .project-tagline {
    font-size: 0.85rem;
    color: var(--gold-primary);
    font-weight: 600;
    margin: 0;
  }

  .project-description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
    flex: 1;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .project-links {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--border);
  }
</style>
