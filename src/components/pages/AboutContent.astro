---
import BaseLayout from '../layout/BaseLayout.astro';
import Badge from '../ui/Badge.astro';
import { getTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/translations';

const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const ta = t.about;

const statsValues = ['40%', '60%', '70%', '10+'];

const skillGroups = [
  { label: 'Architecture', skills: ['.NET', 'Microservices', 'DDD', 'Clean Architecture', 'CQRS', 'Event-Driven'] },
  { label: 'Frontend',     skills: ['React', 'TypeScript', 'TailwindCSS', 'Vite'] },
  { label: 'DevOps',       skills: ['CI/CD', 'Kubernetes', 'Helm', 'Azure DevOps', 'Docker'] },
  { label: 'Databases',    skills: ['PostgreSQL', 'MongoDB', 'SQLite', 'EF Core'] },
];

const companyLogos: Record<string, string> = {
  'TOTVS':       '/images/companies/totvs-logo.jpg',
  'MindCircle':  '/images/mindcircle-icon.svg',
  'Blip':        '/images/companies/blip-logo.jpg',
  'TCE-MG':      '/images/companies/tce-logo.jpg',
  'Raro Labs':   '/images/companies/raro-logo.jpg',
  'dti digital': '/images/companies/dti-logo.jpg',
};

const education = [
  { institution: 'PUC-MG', degree: ta.eduDegrees[0], period: '2020 — 2021' },
  { institution: 'PUC-MG', degree: ta.eduDegrees[1], period: '2013 — 2018' },
];

const socialLinks = [
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/paulaolileal/',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'GitLab',
    href: 'https://gitlab.com/users/paulaolileal/',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23 13.45a.84.84 0 0 1-.35.94z"/></svg>`,
  },
  {
    label: 'GitHub',
    href: 'https://github.com/paulaolileal',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  },
];
---

<BaseLayout title={ta.meta.title} description={ta.meta.description}>

  <div class="about-page">
    <div class="container about-layout">

      <!-- ══════════════════════════════════ LEFT COLUMN -->
      <div class="about-content">

        <div class="about-intro reveal">
          <span class="section-label">{ta.label}</span>
          <span class="gold-line"></span>
          <h1 class="about-name">Paula Leal</h1>
          <p class="about-title">
            {ta.title1}
            <span class="title-dot" aria-hidden="true">·</span>
            {ta.title2}
          </p>
          <p class="about-bio">{ta.bio}</p>
        </div>

        <div class="about-stats reveal reveal-delay-1">
          {statsValues.map((value, i) => (
            <div class="stat-card">
              <span class="stat-value">{value}</span>
              <span class="stat-label">{ta.statsLabels[i]}</span>
            </div>
          ))}
        </div>

        <div class="about-section reveal reveal-delay-2">
          <h2 class="about-section-title">
            <span class="section-label">{ta.experienceLabel}</span>
          </h2>
          <div class="timeline">
            {ta.timeline.map(item => (
              <div class:list={['timeline-item', { current: item.current }]}>
                <div class="timeline-dot" aria-hidden="true">
                  {item.current && <span class="timeline-dot-pulse"></span>}
                </div>
                <div class="timeline-body">
                  <div class="timeline-header">
                    {companyLogos[item.company] && (
                      <div class="timeline-logo">
                        <img src={companyLogos[item.company]} alt={item.company} loading="lazy" />
                      </div>
                    )}
                    <span class="timeline-company">{item.company}</span>
                    {item.current && <span class="current-badge">{ta.currentBadge}</span>}
                  </div>
                  <span class="timeline-role">{item.role}</span>
                  <span class="timeline-period">{item.period}</span>
                  {(item as { highlight?: string }).highlight && (
                    <span class="timeline-highlight">{(item as { highlight?: string }).highlight}</span>
                  )}
                  {(item as { bullets?: string[] }).bullets && (item as { bullets?: string[] }).bullets!.length > 0 && (
                    <ul class="timeline-bullets">
                      {(item as { bullets?: string[] }).bullets!.map(b => (
                        <li>{b}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="about-section reveal reveal-delay-2">
          <h2 class="about-section-title">
            <span class="section-label">{ta.skillsLabel}</span>
          </h2>
          <div class="skills-groups">
            {skillGroups.map(group => (
              <div class="skill-group">
                <span class="skill-group-label">{group.label}</span>
                <div class="skill-group-badges">
                  {group.skills.map(skill => (
                    <Badge variant="tech">{skill}</Badge>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="about-section reveal reveal-delay-3">
          <h2 class="about-section-title">
            <span class="section-label">{ta.educationLabel}</span>
          </h2>
          <div class="education-list">
            {education.map(edu => (
              <div class="education-item">
                <div class="education-marker" aria-hidden="true"></div>
                <div class="education-body">
                  <span class="education-institution">{edu.institution}</span>
                  <span class="education-degree">{edu.degree}</span>
                  <span class="education-period">{edu.period}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="about-social reveal reveal-delay-3">
          {socialLinks.map(link => (
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={link.label}>
              <Fragment set:html={link.icon} />
              <span>{link.label}</span>
            </a>
          ))}
        </div>

      </div>

      <!-- ══════════════════════════════════ RIGHT COLUMN -->
      <aside class="about-photo-col reveal">
        <div class="photo-frame">
          <img
            src="/images/paula-photo.jpg"
            alt={ta.photoAlt}
            class="photo-img"
            width="480"
            height="640"
          />
          <div class="photo-caption">
            <span class="photo-name">Paula Leal</span>
            <span class="photo-role">{ta.photoRole}</span>
          </div>
        </div>

        <div class="quick-facts">
          <div class="quick-fact">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <span>{ta.location}</span>
          </div>
          <div class="quick-fact">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
            <span>TOTVS · MindCircle</span>
          </div>
          <div class="quick-fact">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
            <span>.NET · React · Cloud-Native</span>
          </div>
        </div>
      </aside>

    </div>
  </div>

</BaseLayout>

<style>
  .about-page { padding-block: var(--space-4xl); }

  .about-layout {
    display: grid;
    grid-template-columns: 60fr 40fr;
    gap: var(--space-4xl);
    align-items: start;
  }

  .about-content { display: flex; flex-direction: column; gap: var(--space-3xl); }

  .about-intro { display: flex; flex-direction: column; gap: var(--space-sm); }

  .about-name {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-top: var(--space-xs);
    line-height: 1.05;
  }

  .about-title {
    font-size: 1rem;
    color: var(--gold-primary);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .title-dot { color: var(--border-accent); }

  .about-bio {
    margin-top: var(--space-sm);
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 600px;
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: all var(--transition);
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--gold-primary);
    opacity: 0;
    transition: opacity var(--transition);
  }

  .stat-card:hover { border-color: rgba(200,151,58,0.3); background: var(--bg-card-hover); transform: translateX(2px); }
  .stat-card:hover::before { opacity: 1; }

  .stat-card .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: var(--gold-primary);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-card .stat-label {
    font-family: var(--font-body);
    font-size: 0.825rem;
    color: var(--text-secondary);
    line-height: 1.4;
    text-transform: none;
    letter-spacing: 0;
  }

  .about-section { display: flex; flex-direction: column; gap: var(--space-xl); }
  .about-section-title { font-size: inherit; }

  .timeline { display: flex; flex-direction: column; gap: 0; position: relative; }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px; top: 8px; bottom: 8px;
    width: 2px;
    background: linear-gradient(to bottom, var(--gold-primary) 0%, var(--gold-dim) 30%, var(--border) 100%);
    border-radius: 2px;
  }

  .timeline-item { display: flex; gap: var(--space-lg); padding-block: var(--space-md); position: relative; }

  .timeline-dot {
    width: 16px; height: 16px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--border-accent);
    flex-shrink: 0;
    margin-top: 3px;
    position: relative;
    transition: border-color var(--transition);
    z-index: 1;
  }

  .timeline-item.current .timeline-dot { border-color: var(--gold-primary); background: var(--gold-primary); }

  .timeline-dot-pulse {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 28px; height: 28px;
    border-radius: 50%;
    background: rgba(200, 151, 58, 0.2);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: translate(-50%,-50%) scale(1);   opacity: 0.6; }
    50%       { transform: translate(-50%,-50%) scale(1.5); opacity: 0; }
  }

  .timeline-body {
    display: flex; flex-direction: column; gap: 3px;
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border);
    flex: 1;
  }

  .timeline-item:last-child .timeline-body { border-bottom: none; }

  .timeline-header { display: flex; align-items: center; gap: var(--space-sm); flex-wrap: wrap; }

  .timeline-logo {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .timeline-logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .timeline-company { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--text-primary); letter-spacing: -0.01em; }

  .current-badge {
    font-family: var(--font-mono); font-size: 0.6rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    color: #4ADE80; background: rgba(74,222,128,0.1); border: 1px solid rgba(74,222,128,0.25);
    padding: 2px 8px; border-radius: 999px;
  }

  .timeline-role   { font-size: 0.875rem; font-weight: 600; color: var(--gold-primary); }
  .timeline-period { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-muted); letter-spacing: 0.04em; }

  .timeline-highlight {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.45;
    font-style: italic;
    opacity: 0.85;
    margin-top: 2px;
  }

  .timeline-bullets {
    list-style: none;
    padding: 0;
    margin: var(--space-sm) 0 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .timeline-bullets li {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.5;
    padding-left: var(--space-md);
    position: relative;
  }

  .timeline-bullets li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--gold-primary);
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.2;
  }

  .skills-groups { display: flex; flex-direction: column; gap: var(--space-lg); }
  .skill-group   { display: flex; flex-direction: column; gap: var(--space-sm); }

  .skill-group-label {
    font-family: var(--font-mono); font-size: 0.7rem; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted);
  }

  .skill-group-badges { display: flex; flex-wrap: wrap; gap: var(--space-xs); }

  .education-list { display: flex; flex-direction: column; gap: var(--space-lg); }
  .education-item { display: flex; gap: var(--space-lg); align-items: flex-start; }

  .education-marker { width: 10px; height: 10px; border-radius: 2px; background: var(--gold-primary); flex-shrink: 0; margin-top: 5px; }
  .education-body   { display: flex; flex-direction: column; gap: 4px; }

  .education-institution { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--text-primary); }
  .education-degree      { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.4; }
  .education-period      { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-muted); letter-spacing: 0.05em; }

  .about-social { display: flex; gap: var(--space-md); flex-wrap: wrap; padding-top: var(--space-md); border-top: 1px solid var(--border); }

  .social-link {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.85rem; font-weight: 600;
    color: var(--text-secondary);
    background: var(--bg-card); border: 1px solid var(--border);
    padding: 8px 16px; border-radius: var(--radius-md);
    text-decoration: none; transition: all var(--transition);
  }

  .social-link:hover { color: var(--gold-primary); border-color: rgba(200,151,58,0.3); background: rgba(200,151,58,0.05); transform: translateY(-1px); }

  .about-photo-col {
    position: sticky;
    top: calc(var(--header-height) + var(--space-xl));
    display: flex; flex-direction: column; gap: var(--space-lg);
  }

  .photo-frame { display: flex; flex-direction: column; gap: var(--space-md); }

  .photo-img {
    width: 100%; aspect-ratio: 3 / 4; object-fit: cover; object-position: top center;
    border: 1px solid var(--gold-dim); border-radius: var(--radius-lg); display: block;
    background: linear-gradient(135deg, var(--bg-card) 0%, rgba(200,151,58,0.08) 100%);
  }

  .photo-caption { display: flex; flex-direction: column; gap: 4px; padding-inline: var(--space-xs); }
  .photo-name    { font-family: var(--font-display); font-size: 1.125rem; font-weight: 700; color: var(--text-primary); letter-spacing: -0.01em; }
  .photo-role    { font-family: var(--font-mono); font-size: 0.7rem; font-weight: 500; color: var(--text-muted); letter-spacing: 0.08em; text-transform: uppercase; }

  .quick-facts {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-md); padding: var(--space-lg);
    display: flex; flex-direction: column; gap: var(--space-sm);
  }

  .quick-fact { display: flex; align-items: center; gap: var(--space-sm); font-size: 0.825rem; color: var(--text-secondary); }
  .quick-fact svg { color: var(--gold-primary); flex-shrink: 0; }

  @media (max-width: 1024px) {
    .about-layout { grid-template-columns: 1fr; gap: 0; }
    .about-photo-col { position: static; order: -1; padding-bottom: var(--space-3xl); display: grid; grid-template-columns: auto 1fr; gap: var(--space-xl); align-items: start; }
    .photo-frame { width: 200px; }
    .photo-img   { aspect-ratio: 3 / 4; }
    .quick-facts { grid-column: 2; align-self: start; }
  }

  @media (max-width: 768px) {
    .about-page  { padding-block: var(--space-2xl); }
    .about-stats { grid-template-columns: repeat(2, 1fr); }
    .about-photo-col { display: flex; flex-direction: column; }
    .photo-frame { width: 100%; max-width: 320px; margin-inline: auto; }
  }

  @media (max-width: 480px) {
    .about-stats { grid-template-columns: 1fr; }
  }
</style>
