---
import BaseLayout from '../layout/BaseLayout.astro';
import Badge from '../ui/Badge.astro';
import TechBadge from '../ui/TechBadge.astro';
import Button from '../ui/Button.astro';
import { labProjects } from '../../data/labs';
import { getTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/translations';

const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const tl = t.labs;

const statusLabel: Record<string, string> = {
  active:   tl.active,
  wip:      tl.wip,
  complete: tl.complete,
};

type LabContent = { tagline: string; description: string };
const labsContent = t.labsContent as unknown as Record<string, LabContent>;

const enrichedLabs = labProjects.map((project, i) => {
  const tc = labsContent[project.id];
  const statusVariant = project.status === 'active'
    ? 'status-active'
    : project.status === 'wip'
      ? 'status-wip'
      : 'status-complete';
  return {
    ...project,
    displayTagline: tc?.tagline ?? project.tagline,
    displayDescription: tc?.description ?? project.description,
    statusVariant,
    delayClass: `project-card reveal reveal-delay-${(i % 3) + 1}`,
    idLabel: String(i + 1).padStart(2, "0"),
  };
});
---

<BaseLayout title={tl.meta.title} description={tl.meta.description}>
  <section class="hero section">
    <div class="container">
      <div class="hero-inner reveal">
        <span class="section-label">{tl.label}</span>
        <span class="gold-line"></span>
        <h1>{tl.heading1}<br />{tl.heading2}</h1>
        <p class="hero-sub">{tl.sub}</p>
      </div>
    </div>
  </section>

  <section class="projects-section section-sm">
    <div class="container">
      <div class="projects-grid">
        {enrichedLabs.map(project => (
            <article class={project.delayClass}>
              <div class="card-top">
                <div class="card-header">
                  <Badge variant={project.statusVariant}>
                    {statusLabel[project.status]}
                  </Badge>
                  <span class="project-id">{project.idLabel}</span>
                </div>
                {project.logo && (
                  <div class="card-logo">
                    <img src={project.logo} alt={project.name} width="40" height="40" loading="lazy" />
                  </div>
                )}
                <h3 class="project-name">{project.name}</h3>
                <p class="project-tagline">{project.displayTagline}</p>
              </div>

              <p class="project-description">{project.displayDescription}</p>

              <div class="project-stack">
                {project.techStack.map(tech => (
                  <TechBadge tech={tech} />
                ))}
              </div>

              {(project.href || project.demoUrl || project.gitlabUrl || project.githubUrl) ? (
                <div class="project-links">
                  {project.href && (
                    <Button href={project.href} variant="primary" size="sm">
                      {tl.viewDetails}
                    </Button>
                  )}
                  {project.demoUrl && (
                    <Button href={project.demoUrl} variant="ghost" size="sm" target="_blank" rel="noopener noreferrer">
                      Live Demo
                    </Button>
                  )}
                  {project.gitlabUrl && (
                    <Button href={project.gitlabUrl} variant="ghost" size="sm" target="_blank" rel="noopener noreferrer">
                      GitLab
                    </Button>
                  )}
                  {project.githubUrl && (
                    <Button href={project.githubUrl} variant="ghost" size="sm" target="_blank" rel="noopener noreferrer">
                      GitHub
                    </Button>
                  )}
                </div>
              ) : project.status === 'wip' ? (
                <div class="project-private">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                  </svg>
                  {tl.privateRepo}
                </div>
              ) : null}
            </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-inner { max-width: 680px; }
  .hero-inner h1 { margin-top: var(--space-sm); margin-bottom: var(--space-lg); line-height: 1; }
  .hero-sub { font-size: 1.05rem; color: var(--text-secondary); line-height: 1.7; max-width: 520px; }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 1100px) { .projects-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .projects-grid { grid-template-columns: 1fr; } }

  .project-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-lg);
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
    position: relative; overflow: hidden;
  }

  .project-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-primary), transparent);
    opacity: 0; transition: opacity var(--transition);
  }

  .project-card:hover { border-color: var(--border-accent); transform: translateY(-2px); box-shadow: var(--shadow-card); }
  .project-card:hover::before { opacity: 1; }

  .card-top  { display: flex; flex-direction: column; gap: var(--space-sm); }
  .card-header { display: flex; align-items: center; justify-content: space-between; }

  .card-logo {
    width: 40px; height: 40px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    margin-top: var(--space-xs);
    flex-shrink: 0;
  }
  .card-logo img { width: 100%; height: 100%; object-fit: contain; }

  .project-id      { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-muted); letter-spacing: 0.1em; }
  .project-name    { font-size: clamp(1.25rem, 2.5vw, 1.6rem); font-weight: 700; color: var(--text-primary); line-height: 1.1; }
  .project-tagline { font-size: 0.85rem; color: var(--gold-primary); font-weight: 600; margin: 0; }
  .project-description { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.7; flex: 1; }
  .project-stack { display: flex; flex-wrap: wrap; gap: 6px; }

  .project-links {
    display: flex; gap: var(--space-sm); flex-wrap: wrap;
    padding-top: var(--space-sm); border-top: 1px solid var(--border);
  }

  .project-private {
    display: flex; align-items: center; gap: 6px;
    padding-top: var(--space-sm); border-top: 1px solid var(--border);
    font-family: var(--font-mono); font-size: 0.7rem;
    color: var(--text-muted); letter-spacing: 0.06em;
  }
</style>
