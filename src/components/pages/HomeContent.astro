---
import BaseLayout from '../layout/BaseLayout.astro';
import Button from '../ui/Button.astro';
import TechBadge from '../ui/TechBadge.astro';
import ProductCard from '../sections/ProductCard.astro';
import GameCard from '../sections/GameCard.astro';
import BlogPostCard from '../sections/BlogPostCard.astro';
import { products } from '../../data/products';
import { games } from '../../data/games';
import { labProjects } from '../../data/labs';
import { getCollection } from 'astro:content';
import { getTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/translations';

const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const th = t.home;
const base = locale === 'en' ? '/en' : '';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const mindcircle = products.find(p => p.id === 'mindcircle')!;
const myth = products.find(p => p.id === 'myth')!;

type LabTagline = { tagline: string };
const homeLabsContent = t.labsContent as unknown as Record<string, LabTagline>;
const enrichedHomeLabs = labProjects.map(lab => ({
  ...lab,
  displayTagline: homeLabsContent[lab.id]?.tagline ?? lab.tagline,
}));
---

<BaseLayout title={th.meta.title} description={th.meta.description}>

  <!-- ═══════════════════════════════════════════════════════ HERO -->
  <section class="hero">
    <div class="container hero-container">

      <!-- LEFT: headline + CTA + stats -->
      <div class="hero-left">
        <div class="hero-content">
          <span class="section-label hero-label">LealTEK</span>

          <h1 class="hero-headline">
            {th.heroHeadline1}<br />
            <em>{th.heroHeadline2}</em>
          </h1>

          <p class="hero-sub">{th.heroSub}</p>

          <div class="hero-actions">
            <Button href={`${base}/products`} variant="primary" size="lg">{th.cta1}</Button>
            <Button href={`${base}/about`} variant="secondary" size="lg">{th.cta2}</Button>
          </div>
        </div>

        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-value">10+</span>
            <span class="stat-label">{th.statYears}</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat-item">
            <span class="stat-value">11</span>
            <span class="stat-label">{th.statPackages}</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat-item">
            <span class="stat-value">40%</span>
            <span class="stat-label">{th.statIncidents}</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat-item">
            <span class="stat-value">3</span>
            <span class="stat-label">{th.statGames}</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: floating product cards visual -->
      <div class="hero-visual" aria-hidden="true">
        <!-- MindCircle card -->
        <div class="vis-card vis-card-mc">
          <div class="vis-card-row">
            <div class="vis-logo-wrap vis-logo-mc">
              <img src="/images/mindcircle-icon.jpg" alt="" width="28" height="28" />
            </div>
            <div class="vis-card-info">
              <span class="vis-name">MindCircle</span>
              <span class="vis-type">SaaS Platform</span>
            </div>
            <span class="vis-live-dot"></span>
          </div>
          <div class="vis-chips">
            <span class="vis-chip">.NET 8</span>
            <span class="vis-chip">React 18</span>
            <span class="vis-chip">AI</span>
          </div>
        </div>

        <!-- Myth card -->
        <div class="vis-card vis-card-myth">
          <div class="vis-card-row">
            <div class="vis-logo-wrap vis-logo-myth">
              <img src="/images/myth-logo.png" alt="" width="28" height="28" />
            </div>
            <div class="vis-card-info">
              <span class="vis-name">Myth Ecosystem</span>
              <span class="vis-type">Open Source · NuGet</span>
            </div>
          </div>
          <div class="vis-stat">
            <span class="vis-stat-num">11+</span>
            <span class="vis-stat-label">packages</span>
          </div>
        </div>

        <!-- Labs mini card -->
        <div class="vis-card vis-card-mini vis-card-labs">
          <div class="vis-card-row">
            <div class="vis-logo-wrap vis-logo-labs">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 3h6M10 3v5.5L4.5 18a2 2 0 0 0 1.7 3h11.6a2 2 0 0 0 1.7-3L14 8.5V3" />
              </svg>
            </div>
            <div class="vis-card-info">
              <span class="vis-name">Labs</span>
              <span class="vis-type">{labProjects.length} projects</span>
            </div>
          </div>
        </div>

        <!-- Games mini card -->
        <div class="vis-card vis-card-mini vis-card-games">
          <div class="vis-card-row">
            <div class="vis-logo-wrap vis-logo-games">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 12h4M8 10v4M15 13h.01M18 11h.01M7 6h10a4 4 0 0 1 4 4v4a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4v-4a4 4 0 0 1 4-4Z" />
              </svg>
            </div>
            <div class="vis-card-info">
              <span class="vis-name">Games</span>
              <span class="vis-type">{games.length} titles</span>
            </div>
          </div>
        </div>

        <!-- Floating tech pills, scattered across free space -->
        <div class="vis-pill pill-csharp">C#</div>
        <div class="vis-pill pill-ia">IA</div>

        <div class="vis-pill pill-leadership">Leadership</div>
        <div class="vis-pill pill-clean-arch">Clean Architecture</div>
        <div class="vis-pill pill-ddd">DDD</div>
        <div class="vis-pill pill-solid">SOLID</div>

        <div class="vis-pill pill-postgres">PostgreSQL</div>
        <div class="vis-pill pill-sql">SQL</div>
        <div class="vis-pill pill-typescript">TypeScript</div>
        <div class="vis-pill pill-signalr">SignalR</div>
        <div class="vis-pill pill-kubernetes">Kubernetes</div>
        <div class="vis-pill pill-helm">Helm</div>
        <div class="vis-pill pill-azure">Azure</div>

        <!-- Background glow rings -->
        <div class="vis-ring vis-ring-1"></div>
        <div class="vis-ring vis-ring-2"></div>
      </div>

    </div>

    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-line"></span>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ PRODUCTS -->
  <section class="section" id="products">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">{th.productsLabel}</span>
        <span class="gold-line"></span>
        <h2>{th.productsHeading}</h2>
        <p class="section-description">{th.productsDesc}</p>
      </div>
      <div class="grid-2">
        {products.map((product, i) => (
          <ProductCard product={product} featured class={`reveal reveal-delay-${(i % 3) + 1}`} />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ LABS -->
  <section class="section section-alt" id="labs">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">{th.labsLabel}</span>
        <span class="gold-line"></span>
        <h2>{th.labsHeading}</h2>
        <p class="section-description">{th.labsDesc}</p>
      </div>
      <div class="grid-3">
        {enrichedHomeLabs.map((lab, i) => (
            <article class:list={['lab-card', 'reveal', `reveal-delay-${(i % 3) + 1}`]}>
              <div class="lab-card-top">
                <span class:list={['lab-status', lab.status]}>
                  {lab.status === 'active' ? th.labActive : lab.status === 'wip' ? th.labWip : th.labComplete}
                </span>
                <h3 class="lab-name">{lab.name}</h3>
                <p class="lab-tagline">{lab.displayTagline}</p>
              </div>
              <div class="lab-tags">
                {lab.techStack.slice(0, 2).map(tech => (
                  <TechBadge tech={tech} />
                ))}
              </div>
              {(lab.gitlabUrl || lab.githubUrl || lab.demoUrl) && (
                <a
                  href={lab.demoUrl ?? lab.gitlabUrl ?? lab.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="lab-link"
                >
                  {th.labViewProject}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M7 17L17 7M17 7H7M17 7V17"/>
                  </svg>
                </a>
              )}
            </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ GAMES -->
  <section class="section" id="games">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">{th.gamesLabel}</span>
        <span class="gold-line"></span>
        <h2>{th.gamesHeading}</h2>
        <p class="section-description">{th.gamesDesc}</p>
      </div>
      <div class="grid-2">
        {games.map((game, i) => (
          <GameCard game={game} compact class={`reveal reveal-delay-${(i % 3) + 1}`} />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ BLOG -->
  <section class="section section-alt" id="writing">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">{th.writingLabel}</span>
        <span class="gold-line"></span>
        <h2>{th.writingHeading}</h2>
        <p class="section-description">{th.writingDesc}</p>
      </div>
      <div class="grid-3">
        {latestPosts.map((post, i) => (
          <BlogPostCard
            title={post.data.title}
            date={post.data.date}
            excerpt={post.data.excerpt}
            tags={post.data.tags}
            slug={post.slug}
            linkedinUrl={post.data.linkedinUrl}
            class={`reveal reveal-delay-${(i % 3) + 1}`}
          />
        ))}
      </div>
      <div class="section-cta">
        <a
          href="https://www.linkedin.com/in/paulaolileal/"
          target="_blank"
          rel="noopener noreferrer"
          class="linkedin-cta"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          {th.followLinkedIn}
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ FINAL CTA -->
  <section class="section-cta-banner reveal">
    <div class="container">
      <div class="cta-banner">
        <div class="cta-banner-inner">
          <span class="section-label">{th.ctaLabel}</span>
          <h2 class="cta-banner-headline">{th.ctaHeading}</h2>
          <p class="cta-banner-text">{th.ctaText}</p>
          <Button href={`${base}/contact`} variant="primary" size="lg">{th.ctaBtn}</Button>
        </div>
        <div class="cta-banner-deco" aria-hidden="true">
          <div class="deco-circle deco-circle-1"></div>
          <div class="deco-circle deco-circle-2"></div>
          <div class="deco-circle deco-circle-3"></div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: calc(100vh - var(--header-height));
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding-block: var(--space-4xl);
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .hero-label {
    display: inline-block;
    animation: fadeSlideDown 0.6s ease both;
  }

  .hero-headline {
    font-size: clamp(3rem, 5.5vw, 5.5rem);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    animation: fadeSlideUp 0.7s 0.1s ease both;
  }

  .hero-headline em {
    font-style: normal;
    color: var(--gold-primary);
    position: relative;
    display: inline-block;
  }

  .hero-headline em::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold-primary), var(--gold-light), transparent);
    border-radius: 2px;
    animation: lineGrow 0.8s 0.6s ease both;
    transform-origin: left;
  }

  @keyframes lineGrow {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  .hero-sub {
    font-size: clamp(1rem, 1.4vw, 1.1rem);
    color: var(--text-secondary);
    max-width: 480px;
    line-height: 1.7;
    animation: fadeSlideUp 0.7s 0.2s ease both;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    animation: fadeSlideUp 0.7s 0.3s ease both;
  }

  .hero-stats {
    display: flex;
    align-items: stretch;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    animation: fadeSlideUp 0.7s 0.4s ease both;
    width: fit-content;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--space-md) var(--space-lg);
  }

  .stat-item:hover { background: var(--bg-card-hover); }

  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 800;
    color: var(--gold-primary);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .stat-divider { width: 1px; background: var(--border); flex-shrink: 0; }

  /* ── HERO VISUAL (right side) ── */
  .hero-visual {
    position: relative;
    height: 420px;
    animation: fadeSlideUp 0.8s 0.4s ease both;
  }

  .vis-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(200, 151, 58, 0.08);
    pointer-events: none;
  }

  .vis-ring-1 {
    width: 360px; height: 360px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
  }

  .vis-ring-2 {
    width: 220px; height: 220px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    border-color: rgba(200, 151, 58, 0.12);
  }

  .vis-card {
    position: absolute;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    backdrop-filter: blur(8px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    min-width: 220px;
  }

  .vis-card-mc {
    top: 20px; left: 0;
    border-color: rgba(59, 158, 245, 0.25);
    background: linear-gradient(135deg, var(--bg-card), rgba(59, 158, 245, 0.04));
    animation: float 6s ease-in-out infinite;
  }

  .vis-card-myth {
    bottom: 40px; right: 0;
    border-color: rgba(200, 151, 58, 0.3);
    background: linear-gradient(135deg, var(--bg-card), rgba(200, 151, 58, 0.04));
    animation: float 6s 1.5s ease-in-out infinite;
  }

  .vis-card-mini {
    padding: var(--space-sm) var(--space-md);
    gap: 0;
    min-width: 150px;
  }

  .vis-card-labs {
    top: 46%; left: 0;
    transform: translateY(-50%);
    border-color: rgba(167, 139, 250, 0.3);
    background: linear-gradient(135deg, var(--bg-card), rgba(167, 139, 250, 0.05));
    animation: floatCenterLeft 6s 0.8s ease-in-out infinite;
  }

  .vis-card-games {
    top: 46%; right: 0;
    transform: translateY(-50%);
    border-color: rgba(74, 222, 128, 0.3);
    background: linear-gradient(135deg, var(--bg-card), rgba(74, 222, 128, 0.05));
    animation: floatCenterRight 6s 2.2s ease-in-out infinite;
  }

  @keyframes floatCenterLeft {
    0%, 100% { transform: translateY(-50%); }
    50%       { transform: translateY(calc(-50% - 10px)); }
  }

  @keyframes floatCenterRight {
    0%, 100% { transform: translateY(-50%); }
    50%       { transform: translateY(calc(-50% - 10px)); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-10px); }
  }

  .vis-card-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .vis-logo-wrap {
    width: 36px; height: 36px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    padding: 4px;
    flex-shrink: 0;
  }

  .vis-logo-mc   { background: rgba(59, 158, 245, 0.12); border: 1px solid rgba(59, 158, 245, 0.2); }
  .vis-logo-myth { background: rgba(200, 151, 58, 0.10); border: 1px solid rgba(200, 151, 58, 0.2); }
  .vis-logo-labs  { background: rgba(167, 139, 250, 0.10); border: 1px solid rgba(167, 139, 250, 0.2); color: #A78BFA; }
  .vis-logo-games { background: rgba(74, 222, 128, 0.10); border: 1px solid rgba(74, 222, 128, 0.2); color: #4ADE80; }

  .vis-logo-wrap img { width: 100%; height: 100%; object-fit: contain; }

  .vis-card-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .vis-name { font-weight: 700; font-size: 0.875rem; color: var(--text-primary); }
  .vis-type { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); letter-spacing: 0.06em; }

  .vis-live-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #4ADE80;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.6);
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.7; transform: scale(1.2); }
  }

  .vis-chips {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .vis-chip {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 999px;
    background: rgba(59, 158, 245, 0.08);
    border: 1px solid rgba(59, 158, 245, 0.2);
    color: #60A5FA;
  }

  .vis-stat {
    display: flex;
    align-items: baseline;
    gap: 6px;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--border);
  }

  .vis-stat-num  { font-family: var(--font-display); font-size: 1.75rem; font-weight: 800; color: var(--gold-primary); line-height: 1; }
  .vis-stat-label { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; }

  .vis-pill {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-muted);
    white-space: nowrap;
    pointer-events: none;
    animation: floatPill 7s ease-in-out infinite;
  }

  /*
    Positioning notes: MindCircle/Myth are fixed 220px-wide cards anchored to
    left:0/right:0; Labs/Games mini cards are fixed 150px anchored the same way.
    Pills below use left/right in px (not %) so their clearance from those
    fixed-width cards holds regardless of the hero-visual's actual width —
    a %-based offset would drift into the cards at narrower viewport widths.
  */

  /* center pair — sits in the gap between the Labs and Games mini cards */
  .pill-csharp { top: 44%; left: 47%; transform: translateX(-50%); animation-name: floatPillCentered; animation-delay: 0s; }
  .pill-ia     { top: 52%; left: 53%; transform: translateX(-50%); animation-name: floatPillCentered; animation-delay: 0.6s; }

  /* top-right scatter — cleared of MindCircle's fixed 220px width */
  .pill-leadership { top: 2%;  left: 250px; animation-delay: 0.2s; }
  .pill-clean-arch { top: 15%; left: 246px; animation-delay: 1.4s; }
  .pill-ddd        { top: 27%; left: 300px; animation-delay: 0.8s; }
  .pill-solid      { top: 36%; left: 270px; animation-delay: 2s; }

  /* bottom-left scatter — cleared of Myth's fixed 220px width */
  .pill-postgres   { top: 56%; left: 4px;   animation-delay: 0.4s; }
  .pill-azure      { top: 66%; left: 6px;   animation-delay: 1.2s; }
  .pill-typescript { top: 74%; left: 4px;   animation-delay: 1s; }
  .pill-sql        { top: 83%; left: 6px;   animation-delay: 1.8s; }
  .pill-signalr    { top: 83%; left: 66px;  animation-delay: 0.2s; }

  /* below Myth — full width free */
  .pill-kubernetes { top: 93%; left: 4px;   animation-delay: 1.6s; }
