---
import BaseLayout from '../layout/BaseLayout.astro';
import { getTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/translations';

const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const tn = t.now;
---

<BaseLayout title={tn.meta.title} description={tn.meta.description}>
  <article class="now-page section">
    <div class="container">
      <div class="now-header reveal">
        <h1 class="now-title">Now</h1>
        <span class="now-date">{tn.updated}</span>
      </div>

      <div class="now-body">
        <section class="now-section reveal reveal-delay-1">
          <h2 class="now-section-title">{tn.workingOn}</h2>
          <ul class="now-list">
            {tn.workItems.map(item => (
              <li>
                <span class="now-item-label">{item.label}</span>
                <span class="now-item-desc">{item.desc}</span>
              </li>
            ))}
          </ul>
        </section>

        <section class="now-section reveal reveal-delay-2">
          <h2 class="now-section-title">{tn.learning}</h2>
          <ul class="now-list">
            {tn.learnItems.map(item => (
              <li>
                <span class="now-item-label">{item.label}</span>
                <span class="now-item-desc">{item.desc}</span>
              </li>
            ))}
          </ul>
        </section>

        <section class="now-section reveal reveal-delay-3">
          <h2 class="now-section-title">{tn.readingWatching}</h2>
          <p class="now-empty">{tn.readingEmpty}</p>
        </section>

        <section class="now-section reveal reveal-delay-4">
          <h2 class="now-section-title">{tn.basedIn}</h2>
          <p class="now-location">{tn.location}</p>
        </section>
      </div>

      <footer class="now-footer reveal">
        <p>
          {tn.nowMovement}
          <a href="https://nownownow.com" target="_blank" rel="noopener noreferrer">nownownow.com</a>
        </p>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .now-page { padding-bottom: var(--space-4xl); }

  .now-header {
    margin-bottom: var(--space-3xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
  }

  .now-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin-bottom: var(--space-md);
  }

  .now-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .now-body { display: flex; flex-direction: column; gap: var(--space-3xl); max-width: 680px; }

  .now-section { display: flex; flex-direction: column; gap: var(--space-lg); }

  .now-section-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold-primary);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border);
  }

  .now-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-xl); }

  .now-list li {
    display: flex; flex-direction: column; gap: var(--space-xs);
    padding-left: var(--space-lg); position: relative;
  }

  .now-list li::before {
    content: '—';
    position: absolute; left: 0; top: 0;
    color: var(--gold-dim); font-family: var(--font-mono); font-size: 0.8rem;
  }

  .now-item-label { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: var(--text-primary); letter-spacing: 0.01em; }
  .now-item-desc  { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.65; }
  .now-empty      { font-size: 0.9rem; color: var(--text-muted); font-style: italic; }
  .now-location   { font-size: 1.05rem; color: var(--text-primary); font-family: var(--font-display); font-weight: 600; }

  .now-footer { margin-top: var(--space-4xl); padding-top: var(--space-xl); border-top: 1px solid var(--border); }
  .now-footer p { font-size: 0.8rem; color: var(--text-muted); }
  .now-footer a { color: var(--text-muted); text-decoration: underline; text-underline-offset: 3px; }
  .now-footer a:hover { color: var(--gold-primary); }
</style>
