---
import BaseLayout from '../layout/BaseLayout.astro';
import Button from '../ui/Button.astro';
import Badge from '../ui/Badge.astro';
import TechBadge from '../ui/TechBadge.astro';
import { products, mythPackages, type MythPackage } from '../../data/products';
import { getTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/translations';

const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const tm = t.myth;
const product = products.find(p => p.id === 'myth')!;
const tp = (t.productsContent as any).myth;

const tagline = tp?.tagline ?? product.tagline;
const longDescription = tp?.longDescription ?? product.longDescription;
---

<BaseLayout title={tm.meta.title} description={tm.meta.description}>
  <section class="hero section">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-meta reveal">
          <Badge variant="status-active">{tm.statusActive}</Badge>
          <span class="hero-slash">/</span>
          <span class="hero-category section-label">{tm.category}</span>
        </div>
        <div class="hero-title-row reveal reveal-delay-1">
          {product.logo && (
            <div class="hero-logo">
              <img src={product.logo} alt="Myth Ecosystem" width="64" height="64" />
            </div>
          )}
          <h1 class="hero-title">Myth Ecosystem</h1>
        </div>
        <p class="hero-tagline reveal reveal-delay-2">{tagline}</p>
        <p class="hero-desc reveal reveal-delay-3">{longDescription}</p>
        <div class="hero-actions reveal reveal-delay-4">
          <Button href={product.nugetUrl} variant="primary" size="lg" target="_blank" rel="noopener noreferrer">
            {tm.viewOnNuget}
          </Button>
          <Button href={product.githubUrl} variant="secondary" size="lg" target="_blank" rel="noopener noreferrer">
            {tm.githubSource}
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section class="packages-section section-sm">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">{tm.packagesLabel}</span>
        <span class="gold-line"></span>
        <h2>{tm.packagesHeading}</h2>
        <p class="section-sub">{tm.packagesSub}</p>
      </div>
      <div class="packages-grid">
        {mythPackages.map((pkg: MythPackage, i: number) => (
          <div class={`package-card reveal reveal-delay-${(i % 4) + 1}`}>
            {pkg.logo && (
              <div class="pkg-logo">
                <img src={pkg.logo} alt={pkg.name} width="32" height="32" loading="lazy" />
              </div>
            )}
            <span class="pkg-name">{pkg.name}</span>
            <p class="pkg-desc">{pkg.description}</p>
            <a class="pkg-nuget" href={pkg.nugetUrl} target="_blank" rel="noopener noreferrer">
              {tm.packageNuget} →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="why-section section-sm">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">{tm.philosophyLabel}</span>
        <span class="gold-line"></span>
        <h2>{tm.whyHeading}</h2>
      </div>
      <div class="why-grid">
        {tm.whyPoints.map((point, i) => (
          <div class={`why-card reveal reveal-delay-${i + 1}`}>
            <span class="why-num">0{i + 1}</span>
            <h3 class="why-title">{point.title}</h3>
            <p class="why-desc">{point.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="stack-section section-sm">
    <div class="container">
      <div class="stack-inner reveal">
        <span class="section-label">{tm.builtWithLabel}</span>
        <span class="gold-line"></span>
        <div class="stack-row">
          {product.techStack.map(tech => (
            <TechBadge tech={tech} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section section reveal">
    <div class="container">
      <div class="cta-inner">
        <h2>{tm.ctaHeading}</h2>
        <p>{tm.ctaText}</p>
        <div class="cta-actions">
          <Button href={product.nugetUrl} variant="primary" size="lg" target="_blank" rel="noopener noreferrer">
            {tm.browseNuget}
          </Button>
          <Button href={product.githubUrl} variant="ghost" size="lg" target="_blank" rel="noopener noreferrer">
            {tm.exploreGithub}
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-inner { max-width: 760px; }

  .hero-meta { display: flex; align-items: center; gap: var(--space-md); margin-bottom: var(--space-lg); }
  .hero-slash    { color: var(--border-accent); font-size: 1.2rem; }
  .hero-category { color: var(--text-muted); }

  .hero-title-row { display: flex; align-items: center; gap: var(--space-xl); margin-bottom: var(--space-lg); }

  .hero-logo {
    width: 72px; height: 72px;
    border-radius: 16px;
    background: rgba(200, 151, 58, 0.08);
    border: 1px solid rgba(200, 151, 58, 0.2);
    display: flex; align-items: center; justify-content: center;
    padding: 8px;
    flex-shrink: 0;
  }

  .hero-logo img { width: 100%; height: 100%; object-fit: contain; }

  .hero-title   { font-size: clamp(2.5rem, 7vw, 6rem); font-weight: 800; line-height: 0.95; letter-spacing: -0.03em; }
  .hero-tagline { font-size: clamp(1rem, 2.2vw, 1.3rem); color: var(--gold-primary); font-weight: 600; font-family: var(--font-display); margin-bottom: var(--space-xl); }
  .hero-desc    { font-size: 1rem; color: var(--text-secondary); line-height: 1.75; max-width: 640px; margin-bottom: var(--space-2xl); }
  .hero-actions { display: flex; gap: var(--space-md); flex-wrap: wrap; }

  .section-header { margin-bottom: var(--space-2xl); }
  .section-header h2 { margin-top: var(--space-sm); margin-bottom: var(--space-sm); }
  .section-sub { font-size: 0.95rem; color: var(--text-muted); }

  .packages-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-md); }
  @media (max-width: 1100px) { .packages-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 768px)  { .packages-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px)  { .packages-grid { grid-template-columns: 1fr; } }

  .package-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-md);
    padding: var(--space-lg); display: flex; flex-direction: column; gap: var(--space-sm);
    transition: border-color var(--transition), transform var(--transition);
  }
  .package-card:hover { border-color: rgba(200, 151, 58, 0.25); transform: translateY(-1px); }

  .pkg-logo {
    width: 32px; height: 32px;
    border-radius: 6px;
    overflow: hidden;
    background: rgba(200, 151, 58, 0.06);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 2px;
  }
  .pkg-logo img { width: 100%; height: 100%; object-fit: contain; }

  .pkg-name { font-family: var(--font-mono); font-size: 0.8rem; font-weight: 500; color: var(--gold-primary); letter-spacing: 0.02em; word-break: break-word; }
  .pkg-desc { font-size: 0.8rem; color: var(--text-secondary); line-height: 1.55; margin: 0; flex: 1; }

  .pkg-nuget {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--gold-dim);
    text-decoration: none;
    letter-spacing: 0.06em;
    margin-top: auto;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--border);
    transition: color var(--transition);
    display: block;
  }
  .pkg-nuget:hover { color: var(--gold-primary); }

  .why-section { border-top: 1px solid var(--border); }
  .why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-xl); }
  @media (max-width: 768px) { .why-grid { grid-template-columns: 1fr; } }

  .why-card { display: flex; flex-direction: column; gap: var(--space-md); padding: var(--space-xl); border-left: 2px solid var(--gold-primary); background: var(--bg-card); border-radius: 0 var(--radius-lg) var(--radius-lg) 0; }
  .why-num   { font-family: var(--font-mono); font-size: 0.7rem; color: var(--gold-dim); letter-spacing: 0.1em; }
  .why-title { font-size: 1.2rem; font-weight: 700; color: var(--text-primary); }
  .why-desc  { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.65; }

  .stack-section { border-top: 1px solid var(--border); }
  .stack-inner   { display: flex; flex-direction: column; gap: var(--space-md); }
  .stack-row     { display: flex; flex-wrap: wrap; gap: var(--space-sm); }

  .cta-section { border-top: 1px solid var(--border); }
  .cta-inner   { display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--space-lg); padding-block: var(--space-2xl); max-width: 560px; margin-inline: auto; }
  .cta-inner h2 { font-size: clamp(1.5rem, 3.5vw, 2.25rem); }
  .cta-inner p  { font-size: 0.95rem; color: var(--text-secondary); }
  .cta-actions  { display: flex; gap: var(--space-md); flex-wrap: wrap; justify-content: center; }
</style>
