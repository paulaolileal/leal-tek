---
import BaseLayout from '../layout/BaseLayout.astro';
import GameCard from '../sections/GameCard.astro';
import { games } from '../../data/games';
import { getTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/translations';

const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const tg = t.games;
---

<BaseLayout title={tg.meta.title} description={tg.meta.description}>
  <section class="hero section">
    <div class="container">
      <div class="hero-inner reveal">
        <span class="section-label">{tg.label}</span>
        <span class="gold-line"></span>
        <h1>{tg.heading}</h1>
        <p class="hero-sub">{tg.sub}</p>
      </div>
    </div>
  </section>

  <section class="games-section section-sm">
    <div class="container">
      <div class="games-grid">
        {games.map((game, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <GameCard game={game} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="origin-section section-sm reveal">
    <div class="container">
      <div class="origin-inner">
        <span class="section-label">{tg.originLabel}</span>
        <span class="gold-line"></span>
        <div class="origin-content">
          <p>{tg.originP1}</p>
          <p>{tg.originP2}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-inner { max-width: 600px; }
  .hero-inner h1 { margin-top: var(--space-sm); margin-bottom: var(--space-lg); }
  .hero-sub { font-size: 1.05rem; color: var(--text-secondary); line-height: 1.7; }

  .games-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-xl); }

  @media (max-width: 768px) { .games-grid { grid-template-columns: 1fr; } }

  .origin-section { border-top: 1px solid var(--border); }
  .origin-inner   { max-width: 720px; }

  .origin-content { display: flex; flex-direction: column; gap: var(--space-lg); margin-top: var(--space-md); }
  .origin-content p { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.75; }
</style>
