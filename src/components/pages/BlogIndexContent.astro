---
import { getCollection } from 'astro:content';
import BaseLayout from '../layout/BaseLayout.astro';
import Button from '../ui/Button.astro';
import BlogPostCard from '../sections/BlogPostCard.astro';
import { getTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/translations';

const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const tb = t.blog;

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title={tb.meta.title} description={tb.meta.description} alternatePath={locale === 'en' ? '/blog' : '/en/blog'}>
  <section class="blog-hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <span class="section-label">{tb.label}</span>
          <span class="gold-line"></span>
          <h1>{tb.heading1} <span class="gold">{tb.and}</span> {tb.heading2}</h1>
          <p class="hero-sub">{tb.sub}</p>
          <Button
            href="https://www.linkedin.com/in/paulaolileal/"
            variant="secondary"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            {tb.followLinkedIn}
          </Button>
        </div>

        <div class="hero-decoration" aria-hidden="true">
          <div class="deco-line"></div>
          <span class="deco-count">{posts.length.toString().padStart(2, '0')}</span>
          <span class="deco-label">{tb.postsSuffix}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="blog-list section-sm">
    <div class="container">
      {posts.length > 0 ? (
        <div class="posts-grid">
          {posts.map((entry, i) => (
            <div class:list={['card-wrapper reveal', `reveal-delay-${Math.min(i + 1, 4)}`]}>
              <BlogPostCard
                title={entry.data.title}
                date={entry.data.date}
                excerpt={entry.data.excerpt}
                tags={entry.data.tags}
                slug={entry.slug}
                linkedinUrl={entry.data.linkedinUrl}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state reveal">
          <div class="empty-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
          </div>
          <h3 class="empty-title">{tb.noPostsTitle}</h3>
          <p class="empty-sub">{tb.noPostsSub}</p>
          <Button href="https://www.linkedin.com/in/paulaolileal/" variant="secondary" target="_blank" rel="noopener noreferrer">
            {tb.followLinkedIn}
          </Button>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    padding-block: var(--space-4xl) var(--space-2xl);
    border-bottom: 1px solid var(--border);
    position: relative; overflow: hidden;
  }

  .blog-hero::before {
    content: ''; position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 5% 50%, rgba(200, 151, 58, 0.06) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 95% 20%, rgba(200, 151, 58, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner { display: flex; align-items: flex-end; justify-content: space-between; gap: var(--space-xl); }

  .hero-text { max-width: 560px; display: flex; flex-direction: column; gap: var(--space-md); }
  .hero-text .gold-line { margin-block: 0; }

  .hero-sub { font-size: 1.0625rem; color: var(--text-secondary); line-height: 1.65; margin-bottom: var(--space-sm); }

  .hero-decoration { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; flex-shrink: 0; padding-bottom: 4px; }
  .deco-line  { width: 2px; height: 64px; background: linear-gradient(to bottom, transparent, var(--gold-primary)); margin-bottom: 8px; align-self: center; }
  .deco-count { font-family: var(--font-display); font-size: 3.5rem; font-weight: 800; line-height: 1; color: var(--text-primary); letter-spacing: -0.02em; }
  .deco-label { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); }

  .posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: var(--space-xl); }
  .card-wrapper { height: 100%; }
  .card-wrapper :global(.blog-card) { height: 100%; }

  .empty-state { display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--space-lg); padding: var(--space-4xl) var(--space-xl); max-width: 480px; margin-inline: auto; }
  .empty-icon  { width: 72px; height: 72px; border-radius: var(--radius-lg); background: var(--bg-card); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--text-muted); }
  .empty-title { font-size: 1.25rem; color: var(--text-primary); }
  .empty-sub   { font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.6; margin-top: calc(var(--space-sm) * -1); }

  @media (max-width: 768px) {
    .hero-inner { flex-direction: column; align-items: flex-start; }
    .hero-decoration { display: none; }
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
