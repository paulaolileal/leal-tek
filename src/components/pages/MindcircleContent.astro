---
import BaseLayout from '../layout/BaseLayout.astro';
import Button from '../ui/Button.astro';
import Badge from '../ui/Badge.astro';
import TechBadge from '../ui/TechBadge.astro';
import { products } from '../../data/products';
import { getTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/translations';

const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const tm = t.mindcircle;
const product = products.find(p => p.id === 'mindcircle')!;
const tp = (t.productsContent as any).mindcircle;

const tagline = tp?.tagline ?? product.tagline;
const longDescription = tp?.longDescription ?? product.longDescription;
const features = tp?.features ?? product.features;
const ctaUrl = product.externalUrl!;
---

<BaseLayout title={tm.meta.title} description={tm.meta.description}>
  <section class="hero section">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-meta reveal">
          <Badge variant="status-active">{tm.statusActive}</Badge>
          <span class="hero-slash">/</span>
          <span class="hero-category section-label">{tm.category}</span>
        </div>
        <div class="hero-title-row reveal reveal-delay-1">
          {product.logo && (
            <div class="hero-logo">
              <img src={product.logo} alt="MindCircle" width="64" height="64" />
            </div>
          )}
          <h1 class="hero-title">MindCircle</h1>
        </div>
        <p class="hero-tagline reveal reveal-delay-2">{tagline}</p>
        <p class="hero-desc reveal reveal-delay-3">{longDescription}</p>
        <div class="hero-actions reveal reveal-delay-4">
          <Button href={ctaUrl} variant="primary" size="lg" target="_blank" rel="noopener noreferrer">
            {tm.ctaBtn}
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section class="screenshots-section section-sm">
    <div class="container">
      <div class="screenshots-grid">
        <figure class="screenshot-card reveal reveal-delay-1">
          <img src="/images/mc-home.png" alt="MindCircle — página inicial" loading="lazy" data-lightbox />
          <figcaption>{tm.screenshotHomeCaption}</figcaption>
        </figure>
        <figure class="screenshot-card reveal reveal-delay-2">
          <img src="/images/mc-diagram.png" alt="MindCircle — canvas de diagrama" loading="lazy" data-lightbox />
          <figcaption>{tm.screenshotDiagramCaption}</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="problems-section section-sm">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">{tm.problemsLabel}</span>
        <span class="gold-line"></span>
        <h2>{tm.problemsHeading}</h2>
      </div>
      <div class="problems-grid">
        {tm.problems.map((problem, i) => (
          <div class={`problem-card reveal reveal-delay-${i + 1}`}>
            <span class="problem-num">0{i + 1}</span>
            <h3 class="problem-title">{problem.title}</h3>
            <p class="problem-desc">{problem.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="features-section section-sm">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">{tm.featuresLabel}</span>
        <span class="gold-line"></span>
        <h2>{tm.featuresHeading}</h2>
      </div>
      <div class="features-grid">
        {features.map((feature: { title: string; description: string }, i: number) => (
          <div class={`feature-card reveal reveal-delay-${(i % 3) + 1}`}>
            <span class="feature-num">0{i + 1}</span>
            <h3 class="feature-title">{feature.title}</h3>
            <p class="feature-desc">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="pricing-section section-sm">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">{tm.pricingLabel}</span>
        <span class="gold-line"></span>
        <h2>{tm.pricingHeading}</h2>
      </div>
      <div class="pricing-grid">
        {tm.plans.map((plan, i) => (
          <div class={`pricing-card reveal reveal-delay-${i + 1}${i === 1 ? ' pricing-card--featured' : ''}`}>
            <div class="plan-header">
              <span class="plan-name">{plan.name}</span>
              {i === 1 && <span class="plan-badge">Popular</span>}
            </div>
            <div class="plan-price">
              <span class="plan-amount">{plan.price}</span>
              <span class="plan-period">{plan.period}</span>
            </div>
            <p class="plan-credits">{plan.credits}</p>
            <Button
              href={ctaUrl}
              variant={i === 1 ? 'primary' : 'ghost'}
              size="md"
              target="_blank"
              rel="noopener noreferrer"
            >
              {plan.cta}
            </Button>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="stack-section section-sm">
    <div class="container">
      <div class="stack-inner reveal">
        <span class="section-label">{tm.stackLabel}</span>
        <span class="gold-line"></span>
        <h2>{tm.stackHeading}</h2>
        <div class="stack-grid">
          {product.techStack.map(tech => (
            <TechBadge tech={tech} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section section reveal">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-icon">◎</div>
        <h2>{tm.ctaHeading}</h2>
        <p>{tm.ctaText}</p>
        <Button
          href={ctaUrl}
          variant="primary"
          size="lg"
          target="_blank"
          rel="noopener noreferrer"
        >
          {tm.ctaBtn}
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-inner { max-width: 760px; }

  .hero-meta { display: flex; align-items: center; gap: var(--space-md); margin-bottom: var(--space-lg); }
  .hero-slash    { color: var(--border-accent); font-size: 1.2rem; }
  .hero-category { color: var(--text-muted); }

  .hero-title-row { display: flex; align-items: center; gap: var(--space-xl); margin-bottom: var(--space-lg); }

  .hero-logo {
    width: 72px; height: 72px;
    border-radius: 16px;
    background: rgba(59, 158, 245, 0.1);
    border: 1px solid rgba(59, 158, 245, 0.25);
    display: flex; align-items: center; justify-content: center;
    padding: 8px;
    flex-shrink: 0;
  }

  .hero-logo img { width: 100%; height: 100%; object-fit: contain; }

  .hero-title   { font-size: clamp(3.5rem, 9vw, 7rem); font-weight: 800; line-height: 0.95; letter-spacing: -0.03em; }
  .hero-tagline { font-size: clamp(1.1rem, 2.5vw, 1.4rem); color: var(--gold-primary); font-weight: 600; font-family: var(--font-display); margin-bottom: var(--space-xl); }
  .hero-desc    { font-size: 1rem; color: var(--text-secondary); line-height: 1.75; max-width: 620px; margin-bottom: var(--space-2xl); }
  .hero-actions { display: flex; gap: var(--space-md); flex-wrap: wrap; }

  .section-header { margin-bottom: var(--space-2xl); }
  .section-header h2 { margin-top: var(--space-sm); }

  /* Screenshots */
  .screenshots-section { border-top: 1px solid var(--border); }
  .screenshots-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }
  @media (max-width: 768px) { .screenshots-grid { grid-template-columns: 1fr; } }

  .screenshot-card {
    margin: 0; border-radius: var(--radius-lg); overflow: hidden;
    border: 1px solid var(--border);
    transition: border-color var(--transition), transform var(--transition);
  }
  .screenshot-card:hover { border-color: var(--border-accent); transform: translateY(-2px); }
  .screenshot-card img { width: 100%; height: auto; display: block; }
  .screenshot-card figcaption {
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-mono); font-size: 0.75rem;
    color: var(--text-muted); background: var(--bg-card);
    text-align: center;
  }

  /* Problems */
  .problems-section { border-top: 1px solid var(--border); }
  .problems-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-lg); }
  @media (max-width: 900px) { .problems-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .problems-grid { grid-template-columns: 1fr; } }

  .problem-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-md);
    border-left: 2px solid var(--border-accent);
  }
  .problem-num   { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-muted); letter-spacing: 0.1em; }
  .problem-title { font-size: 1.1rem; font-weight: 700; color: var(--text-primary); }
  .problem-desc  { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.65; }

  /* Features */
  .features-section { border-top: 1px solid var(--border); }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-lg); }
  @media (max-width: 900px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .features-grid { grid-template-columns: 1fr; } }

  .feature-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-md);
    transition: border-color var(--transition), transform var(--transition); position: relative;
  }
  .feature-card:hover { border-color: var(--border-accent); transform: translateY(-2px); }

  .feature-num   { font-family: var(--font-mono); font-size: 0.7rem; color: var(--gold-dim); letter-spacing: 0.1em; }
  .feature-title { font-size: 1.1rem; font-weight: 700; color: var(--text-primary); }
  .feature-desc  { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.65; }

  /* Pricing */
  .pricing-section { border-top: 1px solid var(--border); }
  .pricing-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg); max-width: 780px;
  }
  @media (max-width: 768px) { .pricing-grid { grid-template-columns: 1fr; max-width: 360px; } }

  .pricing-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-lg);
    transition: border-color var(--transition), transform var(--transition);
  }
  .pricing-card--featured {
    border-color: var(--gold-primary);
    box-shadow: 0 0 0 1px rgba(200, 151, 58, 0.15), 0 4px 24px rgba(200, 151, 58, 0.08);
  }

  .plan-header { display: flex; align-items: center; justify-content: space-between; }
  .plan-name   { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--text-primary); }
  .plan-badge  {
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    background: rgba(200, 151, 58, 0.12); color: var(--gold-primary);
    border: 1px solid rgba(200, 151, 58, 0.25);
    padding: 2px 8px; border-radius: 999px;
  }
  .plan-price  { display: flex; align-items: baseline; gap: 4px; }
  .plan-amount { font-family: var(--font-display); font-size: 2.5rem; font-weight: 800; color: var(--text-primary); line-height: 1; }
  .plan-period { font-size: 0.85rem; color: var(--text-muted); }
  .plan-credits { font-family: var(--font-mono); font-size: 0.78rem; color: var(--gold-dim); }

  /* Stack */
  .stack-section { border-top: 1px solid var(--border); }
  .stack-inner   { max-width: 700px; }
  .stack-inner h2 { margin-top: var(--space-sm); margin-bottom: var(--space-xl); }
  .stack-grid { display: flex; flex-wrap: wrap; gap: var(--space-sm); }

  /* CTA */
  .cta-section { border-top: 1px solid var(--border); }
  .cta-inner   { display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--space-lg); padding-block: var(--space-2xl); max-width: 560px; margin-inline: auto; }
  .cta-icon    { font-size: 2.5rem; color: var(--gold-primary); line-height: 1; }
  .cta-inner h2 { font-size: clamp(1.5rem, 3.5vw, 2.25rem); }
  .cta-inner p  { font-size: 0.95rem; color: var(--text-secondary); }
</style>
