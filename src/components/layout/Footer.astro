---
const year = new Date().getFullYear();

const socialLinks = [
  { href: 'https://www.linkedin.com/in/paulaolileal', label: 'LinkedIn', icon: 'in' },
  { href: 'https://gitlab.com/users/paulaolileal/', label: 'GitLab', icon: 'gl' },
  { href: 'https://github.com/paulaolileal', label: 'GitHub', icon: 'gh' },
];

const footerLinks = [
  { href: '/products', label: 'Products' },
  { href: '/labs', label: 'Labs' },
  { href: '/games', label: 'Games' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/now', label: 'Now' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/home">
          <img src="/images/logo-completa.png" alt="LealTEK" width="120" height="38" />
        </a>
        <p class="footer-tagline">
          Engineering ideas into reality —<br />
          software, systems, and open-source.
        </p>
        <div class="social-links">
          {socialLinks.map(link => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="social-btn"
              aria-label={link.label}
            >
              {link.icon === 'in' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              )}
              {link.icon === 'gl' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="m23.955 13.587-1.342-4.135-2.664-8.189a.455.455 0 0 0-.867 0L16.418 9.45H7.582L4.918 1.263a.455.455 0 0 0-.867 0L1.386 9.45.044 13.587a.924.924 0 0 0 .331 1.023L12 23.054l11.625-8.443a.924.924 0 0 0 .33-1.024"/>
                </svg>
              )}
              {link.icon === 'gh' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        {footerLinks.map(link => (
          <a href={link.href} class="footer-link">{link.label}</a>
        ))}
      </nav>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">
        © {year} LealTEK · Paula Leal
      </span>
      <span class="footer-built">
        Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> · Deployed on DigitalOcean
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-surface);
    padding-block: var(--space-3xl) var(--space-xl);
    margin-top: var(--space-4xl);
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-3xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-xl);
  }

  @media (max-width: 640px) {
    .footer-top { flex-direction: column; gap: var(--space-xl); }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 280px;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .social-links {
    display: flex;
    gap: var(--space-sm);
  }

  .social-btn {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition);
  }

  .social-btn:hover {
    border-color: var(--gold-primary);
    color: var(--gold-primary);
    background: rgba(200, 151, 58, 0.08);
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .footer-link:hover { color: var(--gold-primary); }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .footer-copy,
  .footer-built {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .footer-built a { color: var(--text-muted); }
  .footer-built a:hover { color: var(--gold-primary); }
</style>
