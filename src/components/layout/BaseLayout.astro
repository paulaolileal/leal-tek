---
import Header from './Header.astro';
import Footer from './Footer.astro';
import '../../../src/styles/global.css';
import { getTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/translations';

interface Props {
  title: string;
  description?: string;
  image?: string;
  alternatePath?: string;
  showLangSwitcher?: boolean;
}

const {
  title,
  description = 'LealTEK — Software engineering, open-source ecosystems, and digital products built for impact.',
  image = '/images/og-default.png',
  alternatePath,
  showLangSwitcher = true,
} = Astro.props;

const locale = (Astro.currentLocale ?? 'pt') as Locale;
const htmlLang = locale === 'en' ? 'en' : 'pt-BR';

const computedAlternate = alternatePath ?? (
  locale === 'pt'
    ? `/en${Astro.url.pathname}`
    : Astro.url.pathname.replace(/^\/en/, '') || '/'
);

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const alternateURL = new URL(computedAlternate, Astro.site);
const ptURL = locale === 'pt' ? canonicalURL : alternateURL;
const enURL = locale === 'en' ? canonicalURL : alternateURL;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />

    <link rel="alternate" hreflang="pt-BR" href={ptURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={ptURL} />

    <title>{title} — LealTEK</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} — LealTEK`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — LealTEK`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Devicons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/devicon@2.16.0/devicon.min.css" />

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      const saved = localStorage.getItem('lealtek-theme');
      const preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      document.documentElement.dataset.theme = saved || preferred || 'dark';
    </script>
  </head>
  <body>
    <Header alternatePath={computedAlternate} showLangSwitcher={showLangSwitcher} />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Lightbox for zoomable screenshots -->
    <div class="lightbox-overlay" id="lightbox-overlay">
      <button class="lightbox-close" aria-label="Fechar imagem ampliada">&times;</button>
      <img class="lightbox-content" id="lightbox-content" alt="" />
    </div>

    <!-- Scroll reveal observer -->
    <script is:inline>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>

    <!-- Lightbox for zoomable screenshots -->
    <script is:inline>
      const lightboxOverlay = document.getElementById('lightbox-overlay');
      const lightboxContent = document.getElementById('lightbox-content');
      const lightboxClose = document.querySelector('.lightbox-close');

      function openLightbox(src, alt) {
        lightboxContent.src = src;
        lightboxContent.alt = alt || '';
        lightboxOverlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        lightboxOverlay.classList.remove('active');
        document.body.style.overflow = '';
      }

      document.querySelectorAll('img[data-lightbox]').forEach(img => {
        img.addEventListener('click', () => openLightbox(img.currentSrc || img.src, img.alt));
      });

      lightboxOverlay.addEventListener('click', (e) => {
        if (e.target === lightboxOverlay) closeLightbox();
      });
      lightboxClose.addEventListener('click', closeLightbox);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
      });
    </script>
  </body>
</html>

<style is:global>
  img[data-lightbox] {
    cursor: zoom-in;
  }

  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
    background: rgba(6, 7, 8, 0.92);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition);
  }

  .lightbox-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-content {
    max-width: min(90vw, 1400px);
    max-height: 90vh;
    width: auto;
    height: auto;
    border-radius: var(--radius-md);
    box-shadow: 0 8px 60px rgba(0, 0, 0, 0.6);
    cursor: zoom-out;
  }

  .lightbox-close {
    position: fixed;
    top: var(--space-lg);
    right: var(--space-lg);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--border-accent);
    background: var(--bg-surface);
    color: var(--text-primary);
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color var(--transition), color var(--transition);
  }

  .lightbox-close:hover {
    border-color: var(--gold-primary);
    color: var(--gold-primary);
  }
</style>
