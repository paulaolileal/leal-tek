---
import TechBadge from '../ui/TechBadge.astro';
import Button from '../ui/Button.astro';
import { getTranslations } from '../../i18n/utils';
import type { Game } from '../../data/games';
import type { Locale } from '../../i18n/translations';

interface Props {
  game: Game;
}

const { game } = Astro.props;
const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const tg = (t.gamesContent as Record<string, { tagline: string; description: string; features: string[]; disclaimer?: string }>)[game.id];

const base = locale === 'en' ? '/en' : '';
const detailHref = `${base}/games/${game.id}`;

const tagline = tg?.tagline ?? game.tagline;
const description = tg?.description ?? game.description;
const features = tg?.features ?? game.features;
const disclaimer = tg?.disclaimer ?? game.disclaimer;
---

<article class="game-card">
  {game.image && (
    <div class="game-screenshot">
      <img
        src={game.image}
        alt={game.name}
        class="game-img"
        loading="lazy"
        decoding="async"
      />
    </div>
  )}

  <div class="game-header">
    <div class="game-meta">
      <span class="game-players">👥 {game.players}</span>
      <span class="game-time">⏱ {game.playTime}</span>
    </div>
    <h3 class="game-name">{game.name}</h3>
    <p class="game-tagline">{tagline}</p>
  </div>

  <p class="game-description">{description}</p>

  <div class="game-features">
    {features.slice(0, 4).map(f => (
      <span class="feature-item">✓ {f}</span>
    ))}
  </div>

  <div class="game-stack">
    {game.techStack.map(tech => (
      <TechBadge tech={tech} />
    ))}
  </div>

  {disclaimer && (
    <p class="game-disclaimer">⚠ {disclaimer}</p>
  )}

  <div class="game-actions">
    <Button href={game.demoUrl} variant="primary" size="sm" target="_blank" rel="noopener noreferrer">
      {t.components.gamePlayNow}
    </Button>
    <Button href={detailHref} variant="ghost" size="sm">
      {t.components.gameViewDetails}
    </Button>
  </div>
</article>

<style>
  .game-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    transition: all var(--transition);
    position: relative;
    overflow: hidden;
  }

  .game-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold-primary), transparent);
    opacity: 0;
    transition: opacity var(--transition);
    z-index: 1;
  }

  .game-card:hover {
    border-color: var(--border-accent);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  .game-card:hover::before { opacity: 1; }

  .game-screenshot {
    width: 100%;
    height: 200px;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }

  .game-img {
    width: 100%;
    height: 100%;
    object-fit: fill;
    object-position: center;
    display: block;
    transition: transform 0.4s ease;
  }

  .game-card:hover .game-img { transform: scale(1.03); }

  .game-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding-inline: var(--space-xl);
    padding-top: var(--space-lg);
  }

  .game-meta {
    display: flex;
    gap: var(--space-md);
    align-items: center;
  }

  .game-players, .game-time {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .game-name {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--text-primary);
  }

  .game-tagline {
    font-size: 0.9rem;
    color: var(--gold-primary);
    font-weight: 600;
  }

  .game-description {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    padding-inline: var(--space-xl);
  }

  .game-features {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-inline: var(--space-xl);
  }

  .feature-item {
    font-size: 0.825rem;
    color: var(--text-secondary);
  }

  .game-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    padding-inline: var(--space-xl);
  }

  .game-disclaimer {
    font-size: 0.72rem;
    font-style: italic;
    color: var(--text-muted);
    line-height: 1.5;
    padding-inline: var(--space-xl);
  }

  .game-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    padding-inline: var(--space-xl);
    padding-bottom: var(--space-xl);
  }
</style>
