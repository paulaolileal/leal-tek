---
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import { getTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/translations';

interface Props {
  title: string;
  date: Date;
  excerpt: string;
  tags: string[];
  slug: string;
  linkedinUrl: string;
}

const { title, date, excerpt, tags, slug, linkedinUrl } = Astro.props;
const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);

const formattedDate = date.toLocaleDateString(locale === 'pt' ? 'pt-BR' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="blog-card">
  <div class="blog-header">
    <time class="blog-date" datetime={date.toISOString()}>{formattedDate}</time>
    <h3 class="blog-title">
      <a href={`/blog/${slug}`}>{title}</a>
    </h3>
  </div>

  <p class="blog-excerpt">{excerpt}</p>

  <div class="blog-tags">
    {tags.map(tag => (
      <Badge variant="tech">#{tag}</Badge>
    ))}
  </div>

  <div class="blog-actions">
    <Button href={`/blog/${slug}`} variant="ghost" size="sm">{t.components.blogReadMore}</Button>
    <a
      href={linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="linkedin-link"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      {t.components.blogViewLinkedIn}
    </a>
  </div>
</article>

<style>
  .blog-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    transition: all var(--transition);
  }

  .blog-card:hover {
    border-color: var(--border-accent);
    background: var(--bg-card-hover);
    transform: translateY(-1px);
  }

  .blog-header { display: flex; flex-direction: column; gap: var(--space-sm); }

  .blog-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .blog-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .blog-title a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .blog-title a:hover { color: var(--gold-primary); }

  .blog-excerpt {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    flex: 1;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .blog-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .linkedin-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    color: #0A66C2;
    transition: opacity var(--transition);
  }

  .linkedin-link:hover { opacity: 0.8; color: #0A66C2; }
</style>
