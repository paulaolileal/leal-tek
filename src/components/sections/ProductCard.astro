---
import TechBadge from '../ui/TechBadge.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import { getTranslations } from '../../i18n/utils';
import type { Product } from '../../data/products';
import type { Locale } from '../../i18n/translations';

interface Props {
  product: Product;
  featured?: boolean;
}

const { product, featured = false } = Astro.props;
const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const base = locale === 'en' ? '/en' : '';
const tp = (t.productsContent as Record<string, { tagline: string; description: string }>)[product.id];

const tagline = tp?.tagline ?? product.tagline;
const description = tp?.description ?? product.description;
---

<article class:list={['product-card', { featured }]}>
  <div class="card-header">
    <div class="card-header-row">
      {product.logo && (
        <div class="card-logo">
          <img src={product.logo} alt={product.name} width="36" height="36" class="card-logo-img" />
        </div>
      )}
      <Badge variant={product.status === 'active' ? 'status-active' : 'status-wip'}>
        {product.status === 'active' ? t.components.productActive : t.components.productInDev}
      </Badge>
    </div>
    <h3 class="card-name">{product.name}</h3>
    <p class="card-tagline">{tagline}</p>
  </div>

  <p class="card-description">{description}</p>

  <div class="card-stack">
    {product.techStack.slice(0, 5).map(tech => (
      <TechBadge tech={tech} />
    ))}
  </div>

  <div class="card-actions">
    <Button href={`${base}${product.href}`} variant="primary" size="sm">
      {t.components.productViewDetails}
    </Button>
    {product.gitlabUrl && (
      <Button href={product.gitlabUrl} variant="ghost" size="sm" target="_blank" rel="noopener noreferrer">
        GitLab
      </Button>
    )}
  </div>
</article>

<style>
  .product-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    transition: all var(--transition);
    position: relative;
    overflow: hidden;
  }

  .product-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--gold-primary), transparent);
    opacity: 0;
    transition: opacity var(--transition);
  }

  .product-card:hover {
    border-color: var(--border-accent);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  .product-card:hover::before { opacity: 1; }

  .product-card.featured {
    border-color: rgba(200, 151, 58, 0.3);
    background: linear-gradient(135deg, var(--bg-card), rgba(200, 151, 58, 0.03));
  }

  .product-card.featured::before { opacity: 1; }

  .card-header { display: flex; flex-direction: column; gap: var(--space-sm); }

  .card-header-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .card-logo {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(200, 151, 58, 0.08);
    border: 1px solid rgba(200, 151, 58, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-logo-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 4px;
  }

  .card-name {
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    font-weight: 800;
    color: var(--text-primary);
  }

  .card-tagline {
    font-size: 0.875rem;
    color: var(--gold-primary);
    font-weight: 600;
    font-family: var(--font-body);
  }

  .card-description {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    flex: 1;
  }

  .card-stack { display: flex; flex-wrap: wrap; gap: var(--space-xs); }

  .card-actions { display: flex; gap: var(--space-sm); flex-wrap: wrap; }
</style>
